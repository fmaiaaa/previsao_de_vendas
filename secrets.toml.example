# =============================================================================
# Streamlit Cloud → Settings → Secrets (colar como TOML)
# Partilhe cada Google Sheet com o e-mail "client_email" do JSON (função Leitor).
# =============================================================================

# --- Opção A (recomendada): JSON completo numa única chave ---
# Escapar aspas internas ou usar TOML multiline. Exemplo mínimo (uma linha):
# GOOGLE_SERVICE_ACCOUNT_JSON = '{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...@....iam.gserviceaccount.com",...}'

# --- Opção B: secção com as mesmas chaves do ficheiro JSON da Google Cloud ---
# [google_service_account]
# type = "service_account"
# project_id = "seu-projeto"
# private_key_id = "..."
# private_key = """-----BEGIN PRIVATE KEY-----
# MIIE...
# -----END PRIVATE KEY-----
# """
# client_email = "nome@projeto.iam.gserviceaccount.com"
# client_id = "..."
# auth_uri = "https://accounts.google.com/o/oauth2/auth"
# token_uri = "https://oauth2.googleapis.com/token"
# auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
# client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/..."

# --- IDs das planilhas (opcional; por defeito usa os IDs em app.py) ---
# [spreadsheet_ids]
# vendas = "1jb6bYBAlslele2V1CTUVHPNR55SJEiRojN1jGX3gJ4w"
# leads = "1w-htBl8UxwqgFU1bspweBLW54-mzJwFBkcYC0Qib5Wk"

# --- Legado: [id, gid] por base (gid só influencia modo CSV público) ---
# [sheets]
# agendamentos = [ "1TE0J29jxASqd3MbgV6Frwn3kAzlCDf5gzX3I_tmVy1Y", "1490757093" ]

# --- Ordem de tentativa de gid no modo CSV (opcional) ---
# [csv_gid_hints]
# formulario_previsao = [ "155389951", "0" ]
